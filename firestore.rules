rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();

      allow create: if isOwner(userId)
                    && request.resource.data.plan == 'free'
                    && request.resource.data.itemCount == 0
                    && request.resource.data.email is string
                    && request.resource.data.storageMode == 'local'
                    && request.resource.data.aiUsesRemaining == 5
                    && (!('notifyEnabled' in request.resource.data)
                        || request.resource.data.notifyEnabled is bool)
                    && !('role' in request.resource.data);

      allow update: if (isOwner(userId) && request.resource.data.plan == resource.data.plan
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
                    && (
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notifyEnabled'])
                       && request.resource.data.notifyEnabled is bool)
                      ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['itemCount'])
                       && (request.resource.data.itemCount == resource.data.itemCount + 1
                           || request.resource.data.itemCount == resource.data.itemCount - 1)
                       && request.resource.data.itemCount >= 0)
                      ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['aiUsesRemaining'])
                       && request.resource.data.aiUsesRemaining == resource.data.aiUsesRemaining - 1
                       && request.resource.data.aiUsesRemaining >= 0)
                      ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['storageMode','itemCount'])
                       && request.resource.data.storageMode == 'cloud'
                       && hasCloudAccess(resource.data)
                       && request.resource.data.itemCount >= 0)
                      ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['storageMode','itemCount'])
                       && request.resource.data.storageMode == 'local'
                       && request.resource.data.itemCount == 0)
                      ||
                      (hasCloudAccess(resource.data)
                       && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['aiDayKey','aiDayCount','aiMonthKey','aiMonthCount'])
                       && request.resource.data.aiDayCount <= 30
                       && request.resource.data.aiMonthCount <= 300
                       && (request.resource.data.aiDayCount == 1
                           || request.resource.data.aiDayCount == resource.data.aiDayCount + 1)
                       && (request.resource.data.aiMonthCount == 1
                           || request.resource.data.aiMonthCount == resource.data.aiMonthCount + 1))
                      ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['emailVerified'])
                       && request.resource.data.emailVerified is bool)
                      ||
                      (request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['fcmToken','notifyEnabled'])
                       || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmToken'])
                       || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notifyEnabled']))
                    ))
                    || isAdminPlanUpdate();
    }

    match /users/{userId}/warranties/{warrantyId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 200
                    && request.resource.data.keys().hasAll(['name','category','createdAt'])
                    && requiresCloudPlan(userId);

      allow update: if isOwner(userId)
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 200
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['name','category','shop','purchaseDate','warrantyEnd',
                                 'warrantyMonths','docType','docNumber','notes',
                                 'notifyEnabled','docUrl','docMime','docFileName','docStoragePath',
                                 'returnDeadline','notifyDays','notifyReturnDays','notifyRepeatDays']);

      allow delete: if isOwner(userId);
    }

    match /users/{userId}/notif_sent/{sentId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAdminPlanUpdate() {
      return isAdmin()
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['plan'])
             && request.resource.data.plan in ['free', 'premium', 'tester', 'friend'];
    }

    function hasCloudAccess(userData) {
      return userData.plan in ['premium', 'tester', 'friend'] || userData.role == 'admin';
    }

    function requiresCloudPlan(userId) {
      let userDoc = get(/databases/$(database)/documents/users/$(userId));
      return hasCloudAccess(userDoc.data) && userDoc.data.storageMode == 'cloud';
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
